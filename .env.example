# Qwen Cloud / DashScope (international endpoint — we are in Malaysia)
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# Endpoints (intl). Override only if you switch to the Beijing region.
DASHSCOPE_OPENAI_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
DASHSCOPE_HTTP_BASE_URL=https://dashscope-intl.aliyuncs.com/api/v1

# Models
QWEN_TEXT_MODEL=qwen-plus
QWEN_PLAN_MODEL=qwen-max
QWEN_VL_MODEL=qwen-vl-max
WANX_T2I_MODEL=wan2.2-t2i-flash
QWEN_EMBED_MODEL=text-embedding-v3

# Live Pinterest design references (optional — Design Researcher). Costs ~$1/run on Apify.
# Leave APIFY_API_KEY blank (or set ADLOOP_DISABLE_APIFY=1 on a public box) to use the curated fallback for free.
APIFY_API_KEY=
PINTEREST_ACTOR=fatihtahta~pinterest-scraper-search
# ADLOOP_DISABLE_APIFY=1

# SQLite memory store location (defaults to ./data/adloop.db)
# ADLOOP_DB_PATH=
